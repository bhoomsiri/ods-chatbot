# Copy to .env and fill in. All backend vars are prefixed ODS_.

# Set to false to use real services (Qdrant + models + Gemini).
ODS_USE_FAKES=true
ODS_ENVIRONMENT=dev

# Vector store
ODS_QDRANT_URL=http://localhost:6333
ODS_QDRANT_API_KEY=
ODS_QDRANT_COLLECTION=ods_chunks

# Embeddings: "bge_m3" (local, dense+sparse) or "openai" (dense only)
ODS_EMBEDDER=bge_m3
ODS_EMBEDDING_DIM=1024
ODS_OPENAI_API_KEY=
ODS_OPENAI_EMBED_MODEL=text-embedding-3-large

# Reranker
ODS_RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# LLM (Gemini)
ODS_GEMINI_API_KEY=
ODS_GEMINI_ANSWER_MODEL=gemini-2.5-pro
ODS_GEMINI_REFORMULATE_MODEL=gemini-2.5-flash-lite
ODS_ANSWER_TEMPERATURE=0.1

# Retrieval
ODS_RETRIEVAL_TOP_K=20
ODS_RERANK_TOP_K=5
ODS_SCORE_THRESHOLD=0.3

# Admin key — required to upload to the knowledge base (/api/ingest) once the
# app is exposed. MUST be set for any public/demo deploy. Leave blank for local
# dev (ingest then unprotected). Admin browser stores it as localStorage
# "ods-admin-key"; CLI/scripts send header X-Admin-Key.
ODS_ADMIN_KEY=

# Cloudflare Tunnel token (from Zero Trust dashboard). Exposes the frontend to
# the internet without port-forwarding. Required only when running the
# `cloudflared` service. Keep secret — never commit the real value.
CLOUDFLARE_TUNNEL_TOKEN=

# Frontend (Next.js)
# Set to 0 to call the real backend through the /api proxy.
NEXT_PUBLIC_USE_MOCK=0
BACKEND_URL=http://localhost:8000
