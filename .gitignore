# --- Secrets / local config (NEVER commit) ---
.env
.env.local
.env.*.local
*.key
*.pem
# Local Claude Code settings — records permission allowlists that may embed
# secrets (API keys captured in approved commands). Keep local only.
.claude/settings.local.json

# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.mypy_cache/
.pytest_cache/
.ruff_cache/
.coverage
htmlcov/

# --- Node / Next.js (frontend) ---
node_modules/
.next/
out/
.turbo/
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# --- Build / dist ---
dist/
build/

